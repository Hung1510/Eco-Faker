{
  "name": "eco-faker",
  "version": "0.1.0",
  "description": "Stateful, relationally-consistent fake data generator for e-commerce apps: carts, abandoned checkouts, orders, shipments, and returns.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "my-eco-gen": "./dist/cli.js"
  },
  "files": [
    "dist",
    "config.schema.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "web": "node web/server.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@faker-js/faker": "^9.6.0",
    "ajv": "^8.17.1",
    "commander": "^12.1.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
